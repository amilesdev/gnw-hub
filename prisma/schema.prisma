// GNW Worship Hub — Prisma schema
// Use `prisma migrate dev` (not db push) per project conventions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  member
  leader
}

enum MemberSection {
  Vocalist
  Band
}

// A member's part within their section. Soprano/Alto/Tenor are vocal;
// Keys/Guitar/Bass/Drums are band. (The valid set depends on `section`.)
enum MemberPart {
  Soprano
  Alto
  Tenor
  Keys
  Guitar
  Bass
  Drums
}

enum UserStatus {
  pending
  active
}

enum EventType {
  service
  rehearsal
  prayer
  holy_talks
  other
}

enum RepeatCadence {
  once
  weekly
  biweekly
  monthly
}

// === GNW Play ===
// True/False is stored as a degenerate multiple-choice (options ["True","False"]),
// so `type` only distinguishes how the builder/play UI renders it.
enum QuestionType {
  multiple_choice
  true_false
}

enum GameMode {
  classic
  team_battle
  survival
}

// Lifecycle of a leader-initiated group call.
enum CallStatus {
  active
  ended
}

enum SessionStatus {
  lobby
  active
  ended
}

// Round lifecycle. The server owns this; clients render from it but never write.
enum RoundStatus {
  answering
  revealing
  between_rounds
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String?
  role         Role           @default(member)
  section      MemberSection?
  part         MemberPart?
  status       UserStatus     @default(pending)
  // Only one super-admin exists; they alone may grant the leader role.
  isSuperAdmin Boolean        @default(false)
  inviteToken  String?        @unique
  inviteExpiry DateTime?
  // Bumped to invalidate every existing JWT for this user at once (password
  // reset, "sign out everywhere"). The live session check compares the token's
  // copy against this; a mismatch forces re-login. See lib/auth.ts.
  tokenVersion Int            @default(0)
  // Self-serve password reset (active users only). Short-lived, single-use.
  resetToken   String?        @unique
  resetExpiry  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  pushSubscriptions PushSubscription[]

  // GNW Play — all-time wins. Only ever incremented for a game's 1st place;
  // surfaced solely on Play Home + the Play leaderboard (not elsewhere in Hub).
  playPoints Int @default(0)

  questionPacks  QuestionPack[] // packs this user authored
  hostedSessions GameSession[] // game sessions this user hosts
  gamePlayers    GamePlayer[] // this user's seats across sessions

  announcements Announcement[] // announcements this user authored

  startedCalls Call[] // group calls this user (a leader) started
}

// A single device's Web Push subscription. One user can have several (phone,
// laptop, etc.), so subscriptions are per-device, keyed by their unique
// browser endpoint. Removed when the user is deleted or the endpoint expires.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique // the browser push endpoint — dedupe key
  p256dh    String // client public key (from subscription.keys)
  auth      String // client auth secret (from subscription.keys)
  userAgent String? // so a user can recognize which device this is
  createdAt DateTime @default(now())

  @@index([userId])
}

model Event {
  id        String        @id @default(cuid())
  eventName String
  type      EventType     @default(service)
  date      DateTime // calendar day of the occurrence
  time      String // "HH:mm" local label
  location  String
  repeats   RepeatCadence @default(once)
  notes     String?

  // Series grouping — occurrences generated from one recurring create share a seriesId.
  seriesId String?

  // Attire (optional)
  attirePrimary       String?
  attirePrimaryHex    String? // exact swatch color (#RRGGBB) for attirePrimary
  attireSecondary     String?
  attireSecondaryHex  String?
  attireComplement    String?
  attireComplementHex String?
  attireNotes         String?
  attirePhotos        String[] @default([])

  // Holy Talks (optional, holy_talks only)
  topic          String?
  scriptures     String[] @default([])
  holyTalksNotes String?

  // Prayer requests (prayer events only) — members and leaders can both add,
  // and they're visible to everyone. Removed with the event.
  prayerRequests PrayerRequest[]

  // The setlist for this event, if any. One setlist can be shared by several
  // events (e.g. a rehearsal and the service it leads into), but each event has
  // at most one — keeping "This Week's Setlist" unambiguous.
  setlistId String?
  setlist   Setlist? @relation("EventSetlist", fields: [setlistId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seriesId, date]) // one occurrence per slot; makes window top-up idempotent
  @@index([date])
  @@index([seriesId])
  @@index([setlistId])
}

// Records a recurring-series occurrence that a leader deleted on purpose, so the
// rolling-window top-up (ensureRecurringWindow) won't re-create that date.
model SeriesSkip {
  id        String   @id @default(cuid())
  seriesId  String
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([seriesId, date])
  @@index([seriesId])
}

// A prayer request attached to a prayer event. Any active user (member or
// leader) can add one; all are visible to everyone in an ongoing list.
model PrayerRequest {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Author identity is denormalized so the request still reads correctly even
  // if the user is later removed (authorId then dangles, name persists).
  authorId   String?
  authorName String
  body       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId, createdAt])
}

model Setlist {
  id        String   @id @default(cuid())
  name      String? // optional display name; falls back to linked event names when empty.
  month     String // "YYYY-MM" — grouping key, derived from the earliest linked event's date.
  // A setlist can be linked to multiple events (see Event.setlist).
  events    Event[]  @relation("EventSetlist")
  songs     Song[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([month])
}

model Song {
  id                  String    @id @default(cuid())
  setlistId           String
  setlist             Setlist   @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  position            Int // ordering within the setlist
  songTitle           String
  artist              String? // original artist / arranger
  youtubeLink         String?
  driveLink           String? // Google Drive vocal parts fallback
  audioSoprano        String?
  audioAlto           String?
  audioTenor          String?
  audioAllParts       String?
  // Lyric chart imported from a Google Doc. `lyricChart` holds the parsed
  // structured chart (see lib/parseGoogleDoc.ts); `lyricDocUrl` remembers the
  // source doc for re-imports; `lyricChartUpdatedAt` tracks the last import.
  lyricChart          Json?
  lyricDocUrl         String?
  lyricChartUpdatedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([setlistId, position])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  // Pinned announcements sort to the top of everyone's feed and get a
  // highlighted treatment. Toggled by a leader from the Home screen.
  pinned    Boolean  @default(false)
  // The leader who posted it — surfaced as author name + avatar on the card.
  // Nullable so pre-existing posts (and posts by a since-removed user) still show.
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  expiresAt DateTime // required; max 10 days from createdAt (enforced in UI + API)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([pinned])
}

// A team poll created by a leader. Pops up as a blocking prompt for the whole
// team (members + leaders) until each user votes. Results become visible to a
// user the moment they vote (public results); leaders can download the
// distribution once the poll has ended (past `endsAt`).
model Poll {
  id        String       @id @default(cuid())
  question  String
  // Whether a voter may pick more than one choice.
  multiple  Boolean      @default(false)
  // When the poll closes. After this it no longer blocks/accepts votes; leaders
  // can review and download results.
  endsAt    DateTime
  choices   PollChoice[]
  votes     PollVote[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([endsAt])
}

model PollChoice {
  id       String     @id @default(cuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  position Int // ordering within the poll
  text     String
  votes    PollVote[]

  @@index([pollId, position])
}

// One row per (user, choice) selection. A single-answer poll yields one row per
// voter; a multiple-answer poll can yield several. The presence of any row for
// (pollId, userId) means that user has voted.
model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  choiceId  String
  choice    PollChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  // Voter identity kept for one-vote-per-person enforcement and turnout counts.
  // Not a FK to User so a removed user's tallies still stand.
  userId    String
  createdAt DateTime   @default(now())

  @@unique([pollId, userId, choiceId]) // can't pick the same choice twice
  @@index([pollId, userId])
  @@index([choiceId])
}

// ===========================================================================
// GNW Play — real-time quiz game. Lives under /app/play. Server (API routes) is
// the single source of truth for timestamps, scoring, and round state; Supabase
// Realtime Broadcast is only the fast push layer on channel `game:${sessionId}`.
// ===========================================================================

// A reusable set of questions a leader authors in the Pack Builder.
model QuestionPack {
  id          String        @id @default(cuid())
  // Author. Packs are owned content, so they're removed with their creator.
  createdById String?
  creator     User?         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  name        String
  questions   Question[]
  sessions    GameSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdById, updatedAt])
}

model Question {
  id            String       @id @default(cuid())
  packId        String
  pack          QuestionPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  type          QuestionType
  questionText  String
  // MCQ: array of 4 strings. T/F: always ["True","False"].
  options       Json
  // The correct option string, exactly as it appears in `options`.
  correctAnswer String
  orderIndex    Int
  answers       GameAnswer[]
  createdAt     DateTime     @default(now())

  @@index([packId, orderIndex])
}

// One live (or finished) play-through of a pack. Only one session may be in a
// non-ended state across all of Hub at a time (enforced in the API, not the DB).
model GameSession {
  id                   String        @id @default(cuid())
  packId               String
  pack                 QuestionPack  @relation(fields: [packId], references: [id])
  hostId               String
  host                 User          @relation(fields: [hostId], references: [id])
  mode                 GameMode
  status               SessionStatus @default(lobby)
  // { time_per_question, shuffle, team_names? }
  settings             Json
  // Ordered array of question IDs as they will be played.
  questionOrder        Json
  currentQuestionIndex Int           @default(0)
  guestAccessEnabled   Boolean       @default(false)
  guestLinkToken       String?       @unique

  players    GamePlayer[]
  answers    GameAnswer[]
  teams      GameTeam[]
  roundState RoundState?

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([status])
}

// A seat in a session: a Hub user or a named guest (userId null).
model GamePlayer {
  id               String      @id @default(cuid())
  sessionId        String
  session          GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName        String? // used only when userId is null
  team             String? // team_battle only
  hearts           Int         @default(3) // survival only
  isEliminated     Boolean     @default(false)
  isSpectator      Boolean     @default(false)
  playPointsEarned Int         @default(0)
  joinedAt         DateTime    @default(now())

  answers GameAnswer[]

  @@index([sessionId])
  @@index([userId])
}

model GameAnswer {
  id           String      @id @default(cuid())
  sessionId    String
  session      GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId     String
  player       GamePlayer  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question    @relation(fields: [questionId], references: [id])
  answer       String
  // ALWAYS server-recorded (Date.now() in the API route); never client-supplied.
  submittedAt  DateTime
  isCorrect    Boolean?
  // submittedAt − round_state.questionStartAt, computed on the server.
  timeTakenMs  Int?
  pointsEarned Int         @default(0)

  @@unique([playerId, questionId]) // one answer per player per question
  @@index([sessionId, questionId])
}

// Per-session round clock + lifecycle. One row per session (PK = sessionId).
model RoundState {
  sessionId       String      @id
  session         GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Set when the server starts a question; the timing anchor for speed scoring.
  questionStartAt DateTime?
  roundNumber     Int         @default(0)
  status          RoundStatus @default(between_rounds)
}

model GameTeam {
  id         String      @id @default(cuid())
  sessionId  String
  session    GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name       String
  teamPoints Int         @default(0)

  @@index([sessionId])
}

// ===========================================================================
// Calls — leader-initiated live voice/video rooms (LiveKit Cloud). First pass:
// a leader starts a named call, everyone may join (no invite gating yet), and
// a push notification fans out to the whole team. Room media itself lives in
// LiveKit; this row is the discoverable record + audit trail.
// ===========================================================================
model Call {
  id       String     @id @default(cuid())
  name     String // leader-entered call name (free text)
  roomName String     @unique // LiveKit room identifier (unique slug)
  status   CallStatus @default(active)

  // The leader who started the call. Kept as a required FK (the starter always
  // has the leader role, verified server-side at creation).
  startedById String
  startedBy   User   @relation(fields: [startedById], references: [id])

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@index([status])
}
