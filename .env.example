# ----------------------------------------------------------------------------
# GNW Worship Hub — environment variables
# Copy this file to .env.local and fill in real values.
# ----------------------------------------------------------------------------

# --- Database (Supabase Postgres) ---
# Pooled connection (PgBouncer, port 6543) for the app at runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- App URL (used to build invite links in emails) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Storage: attire photos + setlist audio) ---
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only service-role key — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Storage bucket name (create it as a public bucket in Supabase).
SUPABASE_STORAGE_BUCKET="gnw-media"

# --- Resend (transactional email: invites) ---
RESEND_API_KEY="re_your_api_key"
# Must be a verified sender/domain in Resend.
EMAIL_FROM="GNW Worship Hub <noreply@yourdomain.com>"

# --- Super admin (seeded; the only account able to grant leader role) ---
SUPERADMIN_NAME="GNW Admin"
SUPERADMIN_EMAIL="admin@yourdomain.com"
SUPERADMIN_PASSWORD="change-me-on-first-login"
